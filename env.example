# CareRAG_API 環境變數設定檔
# 請複製此檔案為 .env 並填入您的 API 金鑰

# Google Gemini API（若使用 Gemini）
# 取得方式：https://aistudio.google.com/
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
# GEMINI_MODEL_NAME=gemini-3-flash-preview 
GEMINI_MODEL_NAME=gemini-2.0-flash
# Embedding（QA 向量檢索）：使用新 SDK google.genai 時設為 true；預設模型 gemini-embedding-001（Gemini API v1beta 支援）
# USE_GOOGLE_GENAI_SDK=false
# USE_GOOGLE_GENAI_SDK=true
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# DeepSeek API（若使用 DeepSeek）
# 取得方式：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# QA 查詢模式：sql=僅回傳 QA 列表；rag=以檢索結果為 context 呼叫 LLM 產出單一回答（需 GOOGLE_API_KEY）
# QUERY_TYPE=sql
QUERY_TYPE=sql

# QA embedding 搜尋相似度門檻（0.0~1.0；預設 0.60）
# 調低（如 0.50）：放寬命中，適合 QA 資料較少時
# 調高（如 0.70）：嚴格過濾，適合 QA 資料豐富、要求精確時
# QA_MIN_SCORE=0.60

# 日誌等級（可選）
